# Server
PORT=4000

# Database (PostgreSQL)
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=aptech_assessment
# When running locally using `npm run dev`:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aptech_assessment?schema=public
# When running via Docker Compose (the backend container):
# DATABASE_URL=postgresql://postgres:postgres@db:5432/aptech_assessment?schema=public

# Cache & Queue (Redis)
# When running locally:
REDIS_URL=redis://localhost:6379
# When running via Docker Compose:
# REDIS_URL=redis://redis:6379

# JWT Secrets
JWT_SECRET=development_jwt_secret_key_change_me
JWT_REFRESH_SECRET=development_jwt_refresh_secret_key_change_me
